{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Design tokens for <PROJECT_NAME>. Generated by design-system-bootstrap skill.",

  "color": {
    "$type": "color",
    "primary": {
      "light": {
        "$value": "<HEX>",
        "$description": "Primary light — backgrounds, hover states"
      },
      "default": {
        "$value": "<HEX>",
        "$description": "Primary default — buttons, links, main actions"
      },
      "dark": {
        "$value": "<HEX>",
        "$description": "Primary dark — text on light background, action hover"
      }
    },
    "secondary": {
      "light": {
        "$value": "<HEX>",
        "$description": "Secondary light — secondary backgrounds"
      },
      "default": {
        "$value": "<HEX>",
        "$description": "Secondary default — secondary buttons, support elements"
      },
      "dark": {
        "$value": "<HEX>",
        "$description": "Secondary dark — secondary text, hover"
      }
    },
    "accent": {
      "light": {
        "$value": "<HEX>",
        "$description": "Accent light — highlight backgrounds"
      },
      "default": {
        "$value": "<HEX>",
        "$description": "Accent default — badges, highlights, notifications"
      },
      "dark": {
        "$value": "<HEX>",
        "$description": "Accent dark — highlight text"
      }
    },
    "neutral": {
      "50": { "$value": "<HEX>", "$description": "Page background" },
      "100": { "$value": "<HEX>", "$description": "Card background" },
      "200": { "$value": "<HEX>", "$description": "Subtle borders, dividers" },
      "300": { "$value": "<HEX>", "$description": "Default borders, disabled inputs" },
      "400": { "$value": "<HEX>", "$description": "Placeholder text" },
      "500": { "$value": "<HEX>", "$description": "Secondary text" },
      "600": { "$value": "<HEX>", "$description": "Support text" },
      "700": { "$value": "<HEX>", "$description": "Primary text" },
      "800": { "$value": "<HEX>", "$description": "Headings" },
      "900": { "$value": "<HEX>", "$description": "Emphasized text, high contrast" }
    },
    "success": {
      "$value": "<HEX>",
      "$description": "Confirmations, positive states, success badges"
    },
    "warning": {
      "$value": "<HEX>",
      "$description": "Alerts, attention required"
    },
    "error": {
      "$value": "<HEX>",
      "$description": "Errors, failed validation, destructive actions"
    }
  },

  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "primary": {
        "$value": "<FONT_PRIMARY>, <FALLBACK_STACK>",
        "$description": "Primary font for headings and body text"
      },
      "mono": {
        "$value": "<FONT_MONO>, <FALLBACK_STACK>",
        "$description": "Monospace font for code blocks"
      }
    },
    "fontSize": {
      "$type": "dimension",
      "h1": { "$value": "<SIZE_REM>", "$description": "Main page title" },
      "h2": { "$value": "<SIZE_REM>", "$description": "Section title" },
      "h3": { "$value": "<SIZE_REM>", "$description": "Section subtitle" },
      "h4": { "$value": "<SIZE_REM>", "$description": "Card/group title" },
      "h5": { "$value": "<SIZE_REM>", "$description": "Highlight label" },
      "h6": { "$value": "<SIZE_REM>", "$description": "Small label" },
      "body": { "$value": "<SIZE_REM>", "$description": "Default body text" },
      "small": { "$value": "<SIZE_REM>", "$description": "Auxiliary text, captions" },
      "caption": { "$value": "<SIZE_REM>", "$description": "Metadata, timestamps" }
    },
    "lineHeight": {
      "$type": "number",
      "h1": { "$value": "<LH>" },
      "h2": { "$value": "<LH>" },
      "h3": { "$value": "<LH>" },
      "h4": { "$value": "<LH>" },
      "h5": { "$value": "<LH>" },
      "h6": { "$value": "<LH>" },
      "body": { "$value": "<LH>" },
      "small": { "$value": "<LH>" },
      "caption": { "$value": "<LH>" }
    },
    "fontWeight": {
      "$type": "number",
      "regular": { "$value": 400, "$description": "Body text" },
      "medium": { "$value": 500, "$description": "Labels, emphasis" },
      "semibold": { "$value": 600, "$description": "Subheadings" },
      "bold": { "$value": 700, "$description": "Headings, buttons" }
    }
  },

  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px", "$description": "Minimum gap, icon-text spacing" },
    "sm": { "$value": "8px", "$description": "Badge padding, inline item gaps" },
    "sm-md": { "$value": "12px", "$description": "Pill padding, compact list items, icon-label gaps" },
    "md": { "$value": "16px", "$description": "Default element gap, input padding" },
    "lg": { "$value": "24px", "$description": "Container padding, section gaps" },
    "xl": { "$value": "32px", "$description": "Block margins" },
    "2xl": { "$value": "48px", "$description": "Page section separation" },
    "3xl": { "$value": "64px", "$description": "Hero spacing, major area separation" }
  },

  "borderRadius": {
    "$type": "dimension",
    "sm": { "$value": "4px", "$description": "Inputs, badges" },
    "md": { "$value": "8px", "$description": "Cards, buttons" },
    "lg": { "$value": "12px", "$description": "Modals, containers" },
    "full": { "$value": "9999px", "$description": "Avatars, pills" }
  },

  "borderWidth": {
    "$type": "dimension",
    "thin": { "$value": "1px", "$description": "Default borders, dividers" },
    "medium": { "$value": "2px", "$description": "Focus borders, emphasis" }
  },

  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": "<BOX_SHADOW_SM>",
      "$description": "Cards, subtly elevated elements"
    },
    "md": {
      "$value": "<BOX_SHADOW_MD>",
      "$description": "Dropdowns, popovers"
    },
    "lg": {
      "$value": "<BOX_SHADOW_LG>",
      "$description": "Modals, overlays"
    }
  }
}
