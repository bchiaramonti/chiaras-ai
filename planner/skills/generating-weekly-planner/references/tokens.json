{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Weekly Planner Editorial Noturno · design tokens v1.0 · abril 2026. Herda tokens de cor e tipografia do daily, adiciona tokens weekly-specificos (hero-week, day-number, year-cell, fit-screen dimensions).",

  "color": {
    "neutral": {
      "bg": {
        "$value": "#1A1715",
        "$type": "color",
        "$description": "Fundo base da pagina, sempre presente"
      },
      "bg-elevated": {
        "$value": "#2A2320",
        "$type": "color",
        "$description": "Semana atual no year grid"
      },
      "text-primary": {
        "$value": "#F5F0E6",
        "$type": "color",
        "$description": "Textos principais, numero da semana, dias futuros"
      },
      "text-secondary": {
        "$value": "#8A8178",
        "$type": "color",
        "$description": "Horas, metadata, dias passados do Q atual"
      },
      "text-subtle": {
        "$value": "#5A5048",
        "$type": "color",
        "$description": "Semanas de Qs passados, placeholders, sub-labels UPPERCASE"
      },
      "divider": {
        "$value": "#2E2823",
        "$type": "color",
        "$description": "Linhas horizontais entre bands e entre entregas"
      }
    },
    "functional": {
      "accent-primary": {
        "$value": "#D97757",
        "$type": "color",
        "$description": "Terracota · trabalho, foco, Q2 atual, dia alvo, semana atual"
      },
      "accent-secondary": {
        "$value": "#6B9EB0",
        "$type": "color",
        "$description": "Azul petroleo · corpo, treino, TSB positivo, TSS"
      },
      "alert": {
        "$value": "#B8593C",
        "$type": "color",
        "$description": "Terracota escuro · atrasos, sono <7h, TSB <-10, Metas em risco"
      }
    }
  },

  "font": {
    "family": {
      "serif": {
        "$value": ["Georgia", "Source Serif Pro", "serif"],
        "$type": "fontFamily"
      },
      "sans": {
        "$value": ["Inter", "-apple-system", "system-ui", "sans-serif"],
        "$type": "fontFamily"
      }
    },
    "size": {
      "hero-week": { "$value": "72px", "$type": "dimension", "$description": "Numero da semana no hero (band 1)" },
      "hero-word": { "$value": "22px", "$type": "dimension", "$description": "Palavra 'semana' em italic muted ao lado do numero" },
      "day-number": { "$value": "32px", "$type": "dimension", "$description": "Numero do dia em cada coluna da Orquestra" },
      "roman": { "$value": "28px", "$type": "dimension", "$description": "Romanos i./ii./iii. dos Tres grandes" },
      "h2": { "$value": "20px", "$type": "dimension", "$description": "Numeros dos 4 KPIs de Corpo · semana" },
      "lide": { "$value": "17px", "$type": "dimension", "$description": "Prosa da Lide/Tese (levemente maior que daily)" },
      "body-lg": { "$value": "16px", "$type": "dimension" },
      "body": { "$value": "14px", "$type": "dimension" },
      "body-sm": { "$value": "13px", "$type": "dimension" },
      "caption": { "$value": "12px", "$type": "dimension" },
      "label": { "$value": "13px", "$type": "dimension" },
      "micro": { "$value": "11px", "$type": "dimension", "$description": "Metadata, status, meta-label" },
      "micro-upper": { "$value": "9px", "$type": "dimension", "$description": "Sub-labels UPPERCASE (MANHA·DEEP)" },
      "mono": { "$value": "11px", "$type": "dimension" },
      "year-cell": { "$value": "7px", "$type": "dimension", "$description": "Celulas do year grid (52 semanas)" }
    },
    "weight": {
      "light": { "$value": 300, "$type": "fontWeight" },
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight": { "$value": 0.9, "$type": "number" },
      "compact": { "$value": 1.45, "$type": "number" },
      "normal": { "$value": 1.6, "$type": "number" },
      "loose": { "$value": 1.9, "$type": "number" }
    },
    "letterSpacing": {
      "tight": { "$value": "-0.04em", "$type": "dimension", "$description": "Numero da semana hero" },
      "tight-nav": { "$value": "-0.03em", "$type": "dimension", "$description": "Numeros dos dias na Orquestra" },
      "normal": { "$value": "0", "$type": "dimension" },
      "wide": { "$value": "0.1em", "$type": "dimension" },
      "wider": { "$value": "0.12em", "$type": "dimension", "$description": "Sub-labels UPPERCASE" },
      "widest": { "$value": "0.15em", "$type": "dimension", "$description": "Weekday UPPERCASE na Orquestra (SEG, TER, QUA)" }
    }
  },

  "space": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "14px", "$type": "dimension" },
    "5": { "$value": "18px", "$type": "dimension" },
    "6": { "$value": "22px", "$type": "dimension", "$description": "Gap entre bands" },
    "7": { "$value": "24px", "$type": "dimension", "$description": "Gap dentro do band-1 header" },
    "8": { "$value": "32px", "$type": "dimension" },
    "9": { "$value": "36px", "$type": "dimension", "$description": "Gap entre cols de band-3/band-4" }
  },

  "radius": {
    "sm": { "$value": "3px", "$type": "dimension", "$description": "Celula do year grid (semana atual)" },
    "md": { "$value": "6px", "$type": "dimension" }
  },

  "layout": {
    "page": {
      "width-baseline": { "$value": "1440px", "$type": "dimension", "$description": "Largura de referencia do design (Paper). O layout real ocupa 100% do viewport." },
      "height-baseline": { "$value": "1000px", "$type": "dimension", "$description": "Altura de referencia do design (Paper). O layout real usa min-height 100vh." },
      "padding": { "$value": "28px 32px", "$type": "dimension" }
    },
    "band": {
      "gap": { "$value": "22px", "$type": "dimension" },
      "1-min-height": { "$value": "180px", "$type": "dimension", "$description": "Altura minima do header para acomodar hero da semana 72px" },
      "1-gap": { "$value": "24px", "$type": "dimension", "$description": "Gap entre zonas do header" },
      "2-grid-gap": { "$value": "20px", "$type": "dimension", "$description": "Gap entre colunas de dia na Orquestra" },
      "3-gap": { "$value": "36px", "$type": "dimension", "$description": "Gap entre cols de band-3 e band-4" }
    },
    "zones": {
      "semana": { "$value": "220px", "$type": "dimension" },
      "insight": { "$value": "240px", "$type": "dimension" },
      "ano": { "$value": "160px", "$type": "dimension" },
      "corpo": { "$value": "150px", "$type": "dimension" }
    }
  },

  "opacity": {
    "roman": { "$value": 0.5, "$type": "number", "$description": "Romanos i./ii./iii." }
  }
}
