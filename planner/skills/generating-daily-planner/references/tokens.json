{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Planner Editorial Noturno · design tokens v1.0 · abril 2026",

  "color": {
    "neutral": {
      "bg": {
        "$value": "#1A1715",
        "$type": "color",
        "$description": "Fundo base da pagina, sempre presente"
      },
      "bg-elevated": {
        "$value": "#2A2320",
        "$type": "color",
        "$description": "Dia ativo no calendario"
      },
      "text-primary": {
        "$value": "#F5F0E6",
        "$type": "color",
        "$description": "Textos principais, numero da data"
      },
      "text-secondary": {
        "$value": "#8A8178",
        "$type": "color",
        "$description": "Horas, metadata, dias passados"
      },
      "text-subtle": {
        "$value": "#5A5048",
        "$type": "color",
        "$description": "Dias de outros meses, placeholders"
      },
      "divider": {
        "$value": "#2E2823",
        "$type": "color",
        "$description": "Linhas horizontais entre secoes"
      }
    },
    "functional": {
      "accent-primary": {
        "$value": "#D97757",
        "$type": "color",
        "$description": "Terracota · trabalho, foco, pessoal"
      },
      "accent-secondary": {
        "$value": "#6B9EB0",
        "$type": "color",
        "$description": "Azul petroleo · corpo, treino, saude"
      },
      "alert": {
        "$value": "#B8593C",
        "$type": "color",
        "$description": "Terracota escuro · atrasos, prazos criticos"
      }
    }
  },

  "font": {
    "family": {
      "serif": {
        "$value": ["Georgia", "Source Serif Pro", "serif"],
        "$type": "fontFamily"
      },
      "sans": {
        "$value": ["Inter", "-apple-system", "system-ui", "sans-serif"],
        "$type": "fontFamily"
      }
    },
    "size": {
      "display": { "$value": "64px", "$type": "dimension" },
      "h1": { "$value": "40px", "$type": "dimension" },
      "h2": { "$value": "20px", "$type": "dimension" },
      "body-lg": { "$value": "16px", "$type": "dimension" },
      "body": { "$value": "14px", "$type": "dimension" },
      "body-sm": { "$value": "13px", "$type": "dimension" },
      "caption": { "$value": "12px", "$type": "dimension" },
      "label": { "$value": "13px", "$type": "dimension" },
      "mono": { "$value": "11px", "$type": "dimension" }
    },
    "weight": {
      "light": { "$value": 300, "$type": "fontWeight" },
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight": { "$value": 0.9, "$type": "number" },
      "compact": { "$value": 1.45, "$type": "number" },
      "normal": { "$value": 1.6, "$type": "number" },
      "loose": { "$value": 1.9, "$type": "number" }
    },
    "letterSpacing": {
      "tight": { "$value": "-0.04em", "$type": "dimension" },
      "normal": { "$value": "0", "$type": "dimension" },
      "wide": { "$value": "0.1em", "$type": "dimension" }
    }
  },

  "space": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "7": { "$value": "32px", "$type": "dimension" },
    "8": { "$value": "48px", "$type": "dimension" }
  },

  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "6px", "$type": "dimension" }
  },

  "grid": {
    "columns": { "$value": 3, "$type": "number" },
    "gap": { "$value": "32px", "$type": "dimension" },
    "padding": { "$value": "28px 32px", "$type": "dimension" }
  }
}
